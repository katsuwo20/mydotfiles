############################################################
# ls の色分け（GNU ls / WSL想定）
############################################################

# lsで常に色付け
alias ls='ls --color=auto'

# LS_COLORS（見やすさ重視）
export LS_COLORS='di=1;34:ln=1;36:so=1;35:pi=33:ex=1;32:bd=1;33:cd=1;33:su=1;31:sg=1;31:tw=1;34:ow=1;34:mi=1;31:*.tar=1;33:*.tgz=1;33:*.gz=1;33:*.xz=1;33:*.bz2=1;33:*.zip=1;35:*.7z=1;35:*.rar=1;35:*.jpg=1;35:*.png=1;35:*.c=36:*.cpp=36:*.h=36:*.sv=36:*.v=36:*.py=35:*.sh=32:*.zsh=32:*.md=33:'
