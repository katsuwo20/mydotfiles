
############################################################
# .zshrc - メインエントリポイント
# 各設定は ~/.zsh/ 以下に分割
############################################################

# 分割ファイルを読み込み
source ~/.zsh/basic.zsh
source ~/.zsh/completion.zsh
source ~/.zsh/history.zsh
source ~/.zsh/keybind.zsh
source ~/.zsh/prompt.zsh
source ~/.zsh/aliases.zsh
source ~/.zsh/wsl.zsh
source ~/.zsh/colors.zsh
source ~/.zsh/env.zsh
source ~/.zsh/ghq.zsh
source ~/.zsh/local.zsh
